# Example credentials for the Atlassian skill overlay.
#
# Real values belong in ~/.pi/agent/secrets/atlassian.env (chmod 600),
# created by scripts/setup-atlassian.sh. This file is documentation only
# and is the ONLY .env file ever committed to this repo.

# --- Jira ---
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your.email@example.com
# Personal Access Token (Data Center / Server). For Atlassian Cloud, use an API token.
JIRA_PAT_TOKEN=replace-me

# --- Confluence ---
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_USERNAME=your.email@example.com
CONFLUENCE_PAT_TOKEN=replace-me

# --- Bitbucket (optional) ---
# BITBUCKET_URL=https://bitbucket.your-company.com
# BITBUCKET_PAT_TOKEN=replace-me
